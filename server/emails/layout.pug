doctype html
html
  head
    style.
      .body-bg { background-color: #f6f9fc; padding: 20px; font-family: -apple-system, sans-serif; }
      .container { background-color: #ffffff; border: 1px solid #e0e6ed; border-radius: 4px; max-width: 600px; margin: 0 auto; padding: 0; }
      .header-text { font-size: 16px; font-weight: bold; color: #333; margin-bottom: 25px; border-bottom: 1px solid #868686; padding-bottom: 15px; text-align: center; }
      .content-area { padding: 40px; }
      .content-text { color: #282828; font-size: 16px; }
      .footer-section { margin-top: 20px; padding: 20px; background-color: #fcfcfc; border-top: 1px solid #eeeeee; text-align: center; }
      .footer-links { font-size: 12px; color: #8898aa; margin-bottom: 15px; }
      .footer-links a { color: rgb(93, 0, 255); text-decoration: none; margin: 0 10px; font-weight: 500; }
      .address-text { font-size: 11px; color: rgb(133, 133, 133); }
      .btn { display: inline-block; background-color: rgb(93, 0, 255); color: #fff; padding: 12px 20px; text-decoration: none; border-radius: 4px; margin-top: 20px; }
      /* Crucial: Makes the image responsive on small screens */
      .responsive-img { width: 100% !important; height: auto !important; max-width: 600px !important; }
  body.body-bg
    div.container
      
      //- BANNER SECTION (Using Table for maximum compatibility)
      //- REPLACE THE 'src' WITH YOUR ACTUAL PUBLIC LINK
      table(width="100%" border="0" cellspacing="0" cellpadding="0")
        tr
          td(align="center")
            img.responsive-img(
              src="http://rebeca.in/email-banner.png" 
              width="600" 
              alt="Rebeca 2026 Banner" 
              border="0" 
              style="display: block; border-radius: 4px 4px 0 0;"
            )
      
      //- CONTENT SECTION (Added Padding)
      div.content-area
        block content
      
      //- Global Footer Section
      div.footer-section
        div.footer-links
          a(href="https://rebeca.in") Website
          a(href="https://instagram.com/rebeca_iiest") Instagram
          a(href="https://facebook.com/rebeca.iiest") Facebook
          a(href="mailto:support@rebeca.in") Support
        div.address-text
          p © 2026 Rebeca Organizing Committee
          p IIEST, Shibpur, Howrah - 711103